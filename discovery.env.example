# Discovery v4 - Konfigürasyon
# NOT: docker --env-file formatı - 'export' YOK, tırnak YOK

# ─── ANSIBLE ROLES REPO (Bitbucket Server) ─────────────
ANSIBLE_ROLES_REPO_URL=https://bitbucket.sirket.com/scm/devops/ansible-roles.git
ANSIBLE_ROLES_BRANCH=dev

# ─── BITBUCKET (servis repolar + ansible-roles) ────────
BITBUCKET_USER=your-bitbucket-user
BITBUCKET_TOKEN=your-bitbucket-http-access-token

# ─── GITLAB (servis repolar) ───────────────────────────
GITLAB_TOKEN=your-gitlab-personal-access-token

# ─── JENKINS ───────────────────────────────────────────
JENKINS_URL=https://jenkins.sirket.com
JENKINS_USER=your-jenkins-user
JENKINS_TOKEN=your-jenkins-api-token

# ─── ARTIFACTORY (opsiyonel, ileride kullanılacak) ─────
ARTIFACTORY_URL=
ARTIFACTORY_USER=
ARTIFACTORY_TOKEN=

# ─── PERFORMANS / DAVRANIŞ ─────────────────────────────
# Build log'ları çekilsin mi? (yavaş ama doğru)
FETCH_BUILD_LOGS=true

# Servis repo taraması atlansın mı? (sadece test için)
SKIP_REPO_SCAN=false

# Paralel işlem sayıları
PARALLEL_JOBS=4
PARALLEL_REPOS=6

OUTPUT_DIR=/app/output
