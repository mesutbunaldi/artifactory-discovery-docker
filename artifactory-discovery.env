# Artifactory Discovery - Konfigürasyon
# artifactory-discovery.sh ile aynı klasörde olmalı

# ─── Zorunlu ───────────────────────────────────────────
export ARTIFACTORY_URL="https://artifactory.sirket.com/artifactory"
export ARTIFACTORY_USER="your-username"
export ARTIFACTORY_TOKEN="your-api-token-or-password"

# ─── Opsiyonel (default değerleri var) ─────────────────

# Çıktıların yazılacağı klasör
export OUTPUT_DIR="./output"

# Kaç gün geriye gidilecek (aktif servisleri tespit için)
export DAYS_BACK=180

# Paralel API çağrı sayısı (Artifactory'yi yormasın)
export PARALLEL_JOBS=4
