# Artifactory Discovery - Konfigürasyon

# ─── Zorunlu ───────────────────────────────────────────
export ARTIFACTORY_URL="https://artifactory.sirket.com/artifactory"
export ARTIFACTORY_USER="your-username"
export ARTIFACTORY_TOKEN="your-api-token-or-password"

# ─── Opsiyonel ─────────────────────────────────────────
export OUTPUT_DIR="/app/output"
export DAYS_BACK=180
export PARALLEL_JOBS=4

# ─── Generic Repo Tespiti ──────────────────────────────
# Generic repolardaki belirsiz artifact'lerin İÇİNE bakıp manifest dosyalarından
# (META-INF/MANIFEST.MF, package.json, Chart.yaml, .nuspec, vs.) teknoloji tespit et.
#
# true  = Daha doğru tespit ama yavaşlatır (her belirsiz dosya için 1MB indirme)
# false = Sadece dosya uzantısı ve path pattern'i ile tespit (varsayılan, hızlı)
export DEEP_INSPECT="false"

# DEEP_INSPECT=true iken max kaç artifact'in içine bakılsın
export DEEP_INSPECT_LIMIT=50
